# ============================================
# Producción (DigitalOcean) - Referencia
# ============================================
# Sujetarse a esta variable de entorno; no cambiar Google Cloud Console.
# BACKEND_URL y FRONTEND_URL = https://amva.org.es (proxy/routing lleva /api al backend).

NODE_ENV=production
PORT=4000

# Base de datos (Neon)
DATABASE_URL=postgresql://usuario:password@host.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URLs (igual que en tu .env de producción)
BACKEND_URL=https://amva.org.es
FRONTEND_URL=https://amva.org.es

# Google OAuth (login con Google)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALLBACK_URL=/api/auth/invitado/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Email (Brevo)
EMAIL_PROVIDER=brevo-api
BREVO_API_KEY=tu-brevo-api-key
SMTP_FROM_EMAIL=noreply@amva.org.es
SMTP_FROM_NAME=AMVA Digital
